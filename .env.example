# Banco de Dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/sghss?schema=public"

# JWT
JWT_SECRET="sua-chave-secreta-aqui"
JWT_EXPIRES_IN="24h"

# Servidor
PORT=3000
NODE_ENV="development"
